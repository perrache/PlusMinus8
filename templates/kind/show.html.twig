{% extends 'base.html.twig' %}

{% block title %}Kind{% endblock %}

{% block crud %}
    <h1>Kind</h1>

    {{ Table|raw }}
    <tbody>
    <tr>
        <th>Id</th>
        <td>{{ kind.id }}</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>{{ kind.name }}</td>
    </tr>
    </tbody>
    {{ closeTable|raw }}

    <a href="{{ path('app_kind_index') }}">back to list</a>

    <a href="{{ path('app_kind_edit', {'id': kind.id}) }}">edit</a>

    {{ include('kind/_delete_form.html.twig') }}
{% endblock %}
