{% extends 'base.html.twig' %}

{% block title %}Source{% endblock %}

{% block crud %}
    <h1>Source</h1>

    {{ Table|raw }}
    <tbody>
    <tr>
        <th>Id</th>
        <td>{{ source.id }}</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>{{ source.name }}</td>
    </tr>
    </tbody>
    {{ closeTable|raw }}

    <a href="{{ path('app_source_index') }}">back to list</a>

    <a href="{{ path('app_source_edit', {'id': source.id}) }}">edit</a>

    {{ include('source/_delete_form.html.twig') }}
{% endblock %}
