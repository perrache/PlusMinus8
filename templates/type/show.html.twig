{% extends 'base.html.twig' %}

{% block title %}Type{% endblock %}

{% block crud %}
    <h1>Type</h1>

    {{ Table|raw }}
    <tbody>
    <tr>
        <th>Id</th>
        <td>{{ type.id }}</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>{{ type.name }}</td>
    </tr>
    </tbody>
    {{ closeTable|raw }}

    <a href="{{ path('app_type_index') }}">back to list</a>

    <a href="{{ path('app_type_edit', {'id': type.id}) }}">edit</a>

    {{ include('type/_delete_form.html.twig') }}
{% endblock %}
