{% extends 'base.html.twig' %}

{% block title %}Type index{% endblock %}

{% block crud %}
    <h1>Type index</h1>
    <div><a href="{{ path('app_type_new') }}">Create new</a></div>

    {{ Table|raw }}
    <thead>
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>actions</th>
    </tr>
    </thead>
    <tbody>
    {% for type in types %}
        <tr>
            <td>{{ type.id }}</td>
            <td>{{ type.name }}</td>
            <td>
                <a href="{{ path('app_type_show', {'id': type.id}) }}">show</a>
                <a href="{{ path('app_type_edit', {'id': type.id}) }}">edit</a>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="3">no records found</td>
        </tr>
    {% endfor %}
    </tbody>
    {{ closeTable|raw }}

    <div><a href="{{ path('app_type_new') }}">Create new</a></div>
{% endblock %}
