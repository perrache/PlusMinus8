{% extends 'base.html.twig' %}

{% block title %}Currency{% endblock %}

{% block crud %}
    <h1>Currency</h1>

    {{ Table|raw }}
    <tbody>
    <tr>
        <th>Id</th>
        <td>{{ currency.id }}</td>
    </tr>
    <tr>
        <th>Code</th>
        <td>{{ currency.code }}</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>{{ currency.name }}</td>
    </tr>
    </tbody>
    {{ closeTable|raw }}

    <a href="{{ path('app_currency_index') }}">back to list</a>

    <a href="{{ path('app_currency_edit', {'id': currency.id}) }}">edit</a>

    {{ include('currency/_delete_form.html.twig') }}
{% endblock %}
