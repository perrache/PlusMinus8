<!DOCTYPE html>
<html lang="pl" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Welcome{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" type="text/css"
          href="http://localhost:8080/externalCss/style.css?v={{ 'now'|date('YmdHis') }}">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
</head>
<body>
{% set curPath = app.current_route %}
{% set content1 = '<div class="col-xxl-auto gy-2">' %}
{% set content2 = '<div class="col-xxl-auto gy-2">' %}
{% set menu = '<div class="col-xxl-auto gy-2">' %}
{% set closeDiv = '</div>' %}
<div class="container">
    {% include('header.html.twig') %}
    <div class="row gx-5">  {# default = 4 #}
        {{ menu|raw }}
        {% include('menu.html.twig') %}
        {{ closeDiv|raw }}
        {% if curPath|slice(0,4) == 'app_' %}   {# ekrany CRUD w content1 obok menu #}
            {{ content1|raw }}
            {% block crud %}{% endblock %}
            {{ closeDiv }}
        {% else %}
            {% block body %}{% endblock %}
        {% endif %}                             {# pozostałe ekrany zawierają divy z klasami #}
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
        integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
        crossorigin="anonymous"></script>
</body>
</html>
